# App
APP_NAME=ai-crm-automation
DEBUG=true
SECRET_KEY=change-me-in-production
API_KEY=dev-webhook-api-key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_crm
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_crm

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LLM (OpenRouter — free models only)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# HubSpot
HUBSPOT_ACCESS_TOKEN=your-hubspot-token-here

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=lead-uploads

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480
